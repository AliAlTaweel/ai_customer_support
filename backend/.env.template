# --- APP SETTINGS ---
PORT=3001
HOST=127.0.0.1
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
PROJECT_NAME="Luxe AI Support"

# --- AI MODELS ---
# Options: gemini/gemini-1.5-pro, gemini/gemini-1.5-flash, etc.
WORKER_MODEL=gemini/gemini-1.5-flash
GOOGLE_API_KEY=your_google_api_key_here

# --- AUTH (Clerk) ---
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://your-app.clerk.accounts.dev

# --- DATABASE (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# --- VECTOR STORE (FAISS/S3) ---
FAISS_S3_BUCKET=your-bucket-name
FAISS_S3_KEY=faq_index/
INDEX_SAVE_PATH=/tmp/faq_index

# --- AWS CREDENTIALS (S3/RDS Access) ---
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=eu-north-1

# --- GDPR SETTINGS ---
DATA_RETENTION_DAYS=30
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS=10
