generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x", "linux-arm64-openssl-1.0.x", "linux-arm64-openssl-3.0.x"]
  output          = "../src/generated/client"
}

datasource db {
  provider   = "postgresql"
}

/// Represents a SaaS Tenant (Business Workspace) mapped directly to a Clerk Organization.
model Tenant {
  id         String   @id @default(uuid())
  clerkOrgId String   @unique /// Unique Organization ID from Clerk (e.g. org_2xyz...)
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  products      Product[]
  orders        Order[]
  complaints    Complaint[]
  chatMessages  ChatMessage[]
  faqs          FAQ[]
  faqEmbeddings FAQEmbedding[]
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Float
  category    String
  stock       Int         @default(0)
  imageUrl    String
  details     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
  
  /// Identifies the tenant workspace owning this product. Optional during migration.
  tenantId    String?
  tenant      Tenant?     @relation(fields: [tenantId], references: [id])
}

model Order {
  id              String      @id @default(uuid())
  userId          String?
  total           Float
  status          String      @default("PENDING")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  paymentMethod   String?
  shippingAddress String?
  shippingCity    String?
  shippingCountry String?
  shippingState   String?
  shippingZip     String?
  customerEmail   String?
  customerName    String?
  trackingNumber  String?
  carrier         String?     @default("UPS")
  items           OrderItem[]

  /// Identifies the tenant workspace owning this order. Optional during migration.
  tenantId        String?
  tenant          Tenant?     @relation(fields: [tenantId], references: [id])
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id               String   @id @default(uuid())
  role             String
  content          String
  userName         String?
  userId           String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  createdAt        DateTime @default(now())

  /// Identifies the tenant workspace owning this chat session. Optional during migration.
  tenantId         String?
  tenant           Tenant?  @relation(fields: [tenantId], references: [id])
}

model Complaint {
  id            String   @id @default(uuid())
  userId        String?
  customerName  String?
  customerEmail String?
  subject       String
  message       String
  status        String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority      String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  /// Identifies the tenant workspace owning this complaint ticket. Optional during migration.
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Identifies the tenant workspace owning this FAQ item. Optional during migration.
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
}

model FAQEmbedding {
  id        String                 @id @default(uuid())
  tenantId  String
  tenant    Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  text      String
  embedding Unsupported("vector")?
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  @@index([tenantId])
}

