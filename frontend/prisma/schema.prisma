generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          String      @id @default(uuid())
  name        String
  description String
  price       Float
  category    String
  stock       Int         @default(0)
  imageUrl    String
  details     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderItems  OrderItem[]
}

model Order {
  id              String      @id @default(uuid())
  userId          String?
  total           Float
  status          String      @default("PENDING")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  paymentMethod   String?
  shippingAddress String?
  shippingCity    String?
  shippingCountry String?
  shippingState   String?
  shippingZip     String?
  customerEmail   String?
  customerName    String?
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  productId String
  quantity  Int
  price     Float
  product   Product @relation(fields: [productId], references: [id])
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id               String   @id @default(uuid())
  role             String
  content          String
  userName         String?
  userId           String?
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  createdAt        DateTime @default(now())
}
